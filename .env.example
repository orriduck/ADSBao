# Server-only. Required for Postgres-backed airport data, feature flags, route
# feedback, and user map settings.
ADSBAO_DATABASE_URL=
# Browser-visible realtime service endpoint. Use ws://localhost:8080/ws locally.
NEXT_PUBLIC_ADSBAO_REALTIME_URL=
# Optional server-side feature flag scope override: local, preview, or production.
FEATURE_FLAGS_ENV=
AERODATABOX_RAPIDAPI_KEY=
AERODATABOX_RAPIDAPI_HOST=aerodatabox.p.rapidapi.com
OPENAIP_API_KEY=

# Clerk auth. Keep CLERK_SECRET_KEY out of committed files. Sign-in /
# sign-up are rendered as in-page modals (SignInButton mode="modal"),
# so no SIGN_IN_URL / SIGN_UP_URL routes need to be configured.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Sentry onboarding. Keep SENTRY_AUTH_TOKEN out of committed files.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
