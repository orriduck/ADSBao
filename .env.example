# Server-only. Required for Postgres-backed airport data, route feedback, and
# user map settings. Railway usually provides DATABASE_URL automatically.
ADSBAO_DATABASE_URL=
DATABASE_URL=

# Canonical public origin. Production should be https://adsbao.dev.
ADSBAO_SITE_URL=
VITE_SITE_URL=

# Optional browser-visible realtime override. Production normally uses
# same-origin /ws, so leave this unset unless running split local services.
VITE_ADSBAO_REALTIME_URL=

# Optional server-side feature flag scope override: local, preview, or production.
FEATURE_FLAGS_ENV=
OPENAIP_API_KEY=

# Clerk auth. Keep CLERK_SECRET_KEY out of committed files. Sign-in /
# sign-up are rendered as in-page modals (SignInButton mode="modal"),
# so no SIGN_IN_URL / SIGN_UP_URL routes need to be configured.
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# FlightAware realtime access is still gated server-side.
FLIGHTAWARE_ACCESS_ENABLED=
FLIGHTAWARE_FALLBACK_ENABLED=
ADSBAO_REALTIME_AUTH_SECRET=

# New Relic ingest.
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=
